# Backend environment variables
# Copy this file to backend/.env (or export vars in your shell) and fill real values.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER_URI=

S3_BUCKET_NAME=
SQS_EVENT_QUEUE_NAME=

# Development default uses in-memory H2 if DB_URL is omitted.
# For RDS MySQL, set these:
DB_URL=jdbc:mysql://<rds-endpoint>:3306/docuguard?createDatabaseIfNotExist=true
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=
DB_PASSWORD=
DB_DIALECT=org.hibernate.dialect.MySQLDialect
